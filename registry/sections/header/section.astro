---
import type { z } from "zod";
import type { propsSchema } from "./schema.js";

type Props = z.infer<typeof propsSchema>;
const { brand, links, github, cta } = Astro.props as Props;
---

<header class="sticky top-0 z-50 border-b border-border bg-surface backdrop-blur" data-section="header">
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-3 sm:gap-6 sm:px-6 sm:py-4"
    aria-label="Primary"
  >
    <a href="/" class="shrink-0 text-sm font-bold text-fg">{brand}</a>
    <div class="flex min-w-0 items-center gap-4 sm:gap-6">
      {links.map((l) => (
        <a href={l.href} class="hidden text-sm text-muted hover:text-fg sm:inline">{l.label}</a>
      ))}
      {github && (
        <a
          href={github.href}
          class="shrink-0 whitespace-nowrap text-sm text-muted hover:text-fg"
          aria-label="Star on GitHub"
        >
          ★ {github.stars ?? "GitHub"}
        </a>
      )}
      {cta && (
        <a
          href={cta.href}
          class="min-w-0 max-w-[55vw] truncate rounded-[var(--radius)] bg-primary px-3 py-1.5 text-xs font-semibold text-on-primary hover:opacity-90 sm:max-w-none sm:px-4 sm:py-2 sm:text-sm"
        >
          {cta.label}
        </a>
      )}
    </div>
  </nav>
</header>
