---
import { codeToHtml } from "shiki";
import type { z } from "zod";
import type { propsSchema } from "./schema.js";

type Props = z.infer<typeof propsSchema>;
const { heading, subhead, snippets } = Astro.props as Props;

const rendered = await Promise.all(
  snippets.map(async (s) => ({
    label: s.label,
    html: await codeToHtml(s.source, {
      lang: s.lang,
      themes: { light: "github-light", dark: "github-dark" },
    }),
  })),
);
const groupId = `code-${Math.abs(heading.length * 31 + snippets.length)}`;
---

<section class="mx-auto max-w-5xl px-6 py-24" data-section="codeDemo">
  <div class="max-w-2xl">
    <h2 class="text-3xl font-bold tracking-tight text-fg">{heading}</h2>
    {subhead && <p class="mt-3 text-muted">{subhead}</p>}
  </div>
  <div class="mt-10 overflow-hidden rounded-[var(--radius)] border border-border bg-surface" data-codetabs={groupId}>
    <div class="flex gap-1 border-b border-border px-2 pt-2" role="tablist" aria-label="Code language">
      {rendered.map((r, i) => (
        <button
          type="button"
          role="tab"
          aria-selected={i === 0 ? "true" : "false"}
          data-tab={i}
          class="rounded-t-md px-3 py-1.5 text-sm text-muted aria-selected:bg-bg aria-selected:text-fg"
        >
          {r.label}
        </button>
      ))}
    </div>
    {rendered.map((r, i) => (
      <div data-panel={i} hidden={i !== 0} class="overflow-x-auto p-4 text-sm [&_pre]:!bg-transparent" set:html={r.html} />
    ))}
  </div>
</section>

<script>
  for (const group of document.querySelectorAll("[data-codetabs]")) {
    const tabs = group.querySelectorAll("[data-tab]");
    const panels = group.querySelectorAll("[data-panel]");
    for (const tab of tabs) {
      tab.addEventListener("click", () => {
        const idx = tab.getAttribute("data-tab");
        for (const t of tabs) t.setAttribute("aria-selected", t === tab ? "true" : "false");
        for (const p of panels) (p as HTMLElement).hidden = p.getAttribute("data-panel") !== idx;
      });
    }
  }
</script>
