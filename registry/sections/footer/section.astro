---
import type { z } from "zod";
import type { propsSchema } from "./schema.js";

type Props = z.infer<typeof propsSchema>;
const { brand, tagline, columns, copyright } = Astro.props as Props;
---

<footer class="border-t border-border bg-surface" data-section="footer">
  <div class="mx-auto grid max-w-6xl gap-8 px-6 py-14 sm:grid-cols-2 lg:grid-cols-4">
    <div>
      <p class="text-sm font-bold text-fg">{brand}</p>
      {tagline && <p class="mt-2 text-sm text-muted">{tagline}</p>}
    </div>
    {columns.map((col) => (
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-muted">{col.heading}</p>
        <ul class="mt-3 space-y-2">
          {col.links.map((l) => (
            <li><a href={l.href} class="text-sm text-muted hover:text-fg">{l.label}</a></li>
          ))}
        </ul>
      </div>
    ))}
  </div>
  <div class="border-t border-border px-6 py-6">
    <p class="mx-auto max-w-6xl text-xs text-muted">{copyright}</p>
  </div>
</footer>
