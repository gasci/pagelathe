---
import type { z } from "zod";
import type { propsSchema } from "./schema.js";

type Props = z.infer<typeof propsSchema>;
const { heading, subhead, tiers } = Astro.props as Props;
---

<section id="pricing" class="mx-auto max-w-6xl px-6 py-24" data-section="pricing">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-3xl font-bold tracking-tight text-fg">{heading}</h2>
    {subhead && <p class="mt-3 text-muted">{subhead}</p>}
  </div>
  <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {tiers.map((t) => (
      <div class={`flex flex-col rounded-[var(--radius)] border p-7 ${t.featured ? "border-primary bg-surface" : "border-border"}`}>
        <h3 class="text-sm font-semibold text-fg">{t.name}</h3>
        <p class="mt-3"><span class="text-3xl font-bold text-fg">{t.price}</span>{t.period && <span class="text-muted">{t.period}</span>}</p>
        <p class="mt-2 text-sm text-muted">{t.description}</p>
        <ul class="mt-5 flex-1 space-y-2">
          {t.features.map((f) => <li class="text-sm text-muted">✓ {f}</li>)}
        </ul>
        <a href={t.cta.href} class={`mt-6 rounded-[var(--radius)] px-4 py-2.5 text-center text-sm font-semibold ${t.featured ? "bg-primary text-on-primary hover:opacity-90" : "border border-border text-fg hover:bg-fg/5"}`}>
          {t.cta.label}
        </a>
      </div>
    ))}
  </div>
</section>
