---
import { codeToHtml } from "shiki";
import type { z } from "zod";
import type { propsSchema } from "./schema.js";

type Props = z.infer<typeof propsSchema>;
const { variant, eyebrow, headline, subhead, ctas, code, image } = Astro.props as Props;

const ctaClass: Record<string, string> = {
  primary: "bg-primary text-on-primary hover:opacity-90",
  secondary: "border border-border text-fg hover:bg-fg/5",
  ghost: "text-muted hover:text-fg",
};

let codeHtml = "";
if (variant === "code-snippet" && code) {
  codeHtml = await codeToHtml(code.source, {
    lang: code.lang,
    themes: { light: "github-light", dark: "github-dark" },
  });
}
---

<section class="relative mx-auto max-w-6xl px-6 py-24" data-section="hero">
  <div class="grid items-center gap-12 lg:grid-cols-2">
    <div>
      {eyebrow && <p class="mb-3 text-sm font-medium text-primary">{eyebrow}</p>}
      <h1 class="text-4xl font-bold tracking-tight text-fg sm:text-5xl">{headline}</h1>
      <p class="mt-5 text-lg text-muted">{subhead}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        {ctas.map((c) => (
          <a
            href={c.href}
            class={`inline-flex items-center rounded-[var(--radius)] px-5 py-2.5 text-sm font-semibold transition ${ctaClass[c.style]}`}
          >
            {c.label}
          </a>
        ))}
      </div>
    </div>
    <div class="min-w-0">
      {variant === "code-snippet" && code && (
        <div
          class="overflow-x-auto rounded-[var(--radius)] border border-border bg-surface p-4 text-sm [&_pre]:!bg-transparent"
          set:html={codeHtml}
        />
      )}
      {variant === "product-ui" && image && (
        <img
          src={image.src}
          alt={image.alt}
          class="w-full rounded-[var(--radius)] border border-border"
          loading="eager"
          decoding="async"
        />
      )}
    </div>
  </div>
</section>
